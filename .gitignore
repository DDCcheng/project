# ------------------------------------------------------------------
# COMP9444 Project 093 -- what NOT to commit
# ------------------------------------------------------------------

# Dataset images are local-only and must never be committed. Keep the usage
# note tracked while ignoring any extracted image files under data/.
data/*
!data/README.md

# --- Large feature files produced by roles 2 & 3 ---
*.npz
*.pt
*.pth

# --- Python virtual environment ---
.venv/
venv/
env/

# --- Python caches / build ---
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Jupyter ---
.ipynb_checkpoints/

# --- Kaggle credentials (never commit secrets) ---
kaggle.json
.kaggle/

# --- OS / editor cruft ---
.DS_Store
Thumbs.db
.vscode/
.idea/

# --- Claude Code local config / scratch (do not commit) ---
.claude/

# ------------------------------------------------------------------
# NOTE: results/figures, results/tables, docs/file_list.csv and feature files
# are shared team outputs. The dataset itself remains local-only.
# ------------------------------------------------------------------
